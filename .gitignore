# ============================================================
# FIFA Prediction — Root .gitignore
# ============================================================

# Claude
claude
.claude

# ============================================================
# Secrets & credentials — NEVER commit
# ============================================================
.env
.env.local
.env.*
!.env.example

# ============================================================
# Python artifacts
# ============================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.venv/
venv/
env/

# ============================================================
# Jupyter
# ============================================================
.ipynb_checkpoints/

# ============================================================
# dbt artifacts (generated, not source)
# ============================================================
dbt/target/
fifa-pipeline/dbt/target/
dbt/logs/
fifa-pipeline/dbt/logs/
dbt/.user.yml
fifa-pipeline/dbt/.user.yml

# ============================================================
# Airflow artifacts
# ============================================================
airflow/logs/
fifa-pipeline/airflow/logs/
airflow.cfg
airflow.db
standalone_admin_password.txt
airflow/plugins/
fifa-pipeline/airflow/plugins/

# ============================================================
# Model artifacts (generated by pipeline — not manually authored)
# ============================================================
models/*.pkl
models/*.ubj
models/*.json
fifa-pipeline/models/*.pkl
fifa-pipeline/models/*.ubj
fifa-pipeline/models/*.json

# ============================================================
# Data artifacts (large / generated files)
# ============================================================
data/processed/
fifa-pipeline/data/processed/
*.parquet

# ============================================================
# PySpark / Java drivers
# ============================================================
drivers/
fifa-pipeline/drivers/

# ============================================================
# OS files
# ============================================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# Docker local volumes (if ever bind-mounted locally)
# ============================================================
postgres_data/
airflow_logs_local/
